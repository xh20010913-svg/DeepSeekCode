{
  "name": "@xh12312/deepseekcode",
  "version": "0.3.1",
  "private": false,
  "description": "DeepSeek-first local agent workbench, TypeScript runtime.",
  "type": "module",
  "main": "./dist/main.js",
  "bin": {
    "deepseekcode": "dist/cli/main.js"
  },
  "files": [
    "dist",
    "!dist/**/__tests__/**",
    "!dist/**/*.test.js",
    "assets",
    "website",
    "README.md",
    "README.zh-CN.md",
    ".env.example",
    "GUIDE.md",
    "ARCHITECTURE.md",
    "CLI_REFERENCE.md",
    "DEVELOPMENT.md",
    "API_REFERENCE.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-vendor.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:keys": "node --test scripts/test-input-keys.mjs",
    "prepare": "npm run build",
    "dev": "tsx src/cli/main.tsx",
    "start": "node dist/cli/main.js",
    "doctor": "node dist/cli/main.js --doctor"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@node-rs/jieba": "^2.0.1",
    "@tencent-weixin/openclaw-weixin": "2.4.4",
    "@tencentdb-agent-memory/tcvdb-text": "^0.1.1",
    "@wecom/aibot-node-sdk": "^1.0.7",
    "ai": "^6.0.164",
    "commander": "^14.0.2",
    "docx": "^9.7.1",
    "dotenv": "^17.2.3",
    "ink": "^5.2.1",
    "js-tiktoken": "^1.0.18",
    "json5": "^2.2.3",
    "pptxgenjs": "^4.0.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "react": "^18.3.1",
    "sqlite-vec": "^0.1.7-alpha.2",
    "undici": "^8.1.0",
    "ws": "^8.18.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.27",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
