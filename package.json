{
  "name": "deepseekcode",
  "version": "0.1.0",
  "private": true,
  "description": "DeepSeek-first local agent workbench, TypeScript runtime.",
  "type": "module",
  "bin": {
    "deepseekcode": "./dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx src/cli/main.tsx",
    "start": "node dist/cli/main.js",
    "doctor": "node dist/cli/main.js --doctor",
    "smoke": "node scripts/run-tests.mjs",
    "smoke:user": "node scripts/smoke-user-prompts.mjs",
    "parity": "node scripts/parity-check.mjs"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "docx": "^9.7.1",
    "dotenv": "^17.2.3",
    "ink": "^5.2.1",
    "pptxgenjs": "^4.0.1",
    "react": "^18.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.27",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
