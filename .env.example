# Copy this file to .env or set the variables in your local shell.

# deepseekCode v1 is DeepSeek-first. Use flash for live smoke tests.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEKCODE_LANGUAGE=zh-CN
DEEPSEEKCODE_MAX_OUTPUT_TOKENS=1200
DEEPSEEKCODE_REASONING_EFFORT=high

# Optional local cost-estimate overrides, in currency units per 1M tokens.
# DeepSeekCode includes DeepSeek defaults for deepseek-v4-flash/pro.
# DEEPSEEKCODE_PRICE_CURRENCY=USD
# DEEPSEEKCODE_PRICE_INPUT_PER_M=0.14
# DEEPSEEKCODE_PRICE_OUTPUT_PER_M=0.28
# DEEPSEEKCODE_PRICE_CACHE_HIT_PER_M=0.0028
# DEEPSEEKCODE_PRICE_CACHE_MISS_PER_M=0.14

# Optional provider profile JSON path. Prefer api_key_env entries in this file
# and keep real secrets in local environment variables.
# DEEPSEEKCODE_PROVIDER_CONFIG=D:\DeepSeekCodeData\providers.json

# Browser automation.
# DEEPSEEKCODE_BROWSER_CDP_URL=http://127.0.0.1:9222
# DEEPSEEKCODE_SEARCH_ENGINE=baidu

# Multi-agent Agent Panel sharing.
# Local TUI opens the panel automatically. Phones need a LAN URL or HTTPS tunnel.
# DEEPSEEKCODE_AGENT_PANEL_HOST=127.0.0.1
# DEEPSEEKCODE_AGENT_PANEL_PORT=58937
# DEEPSEEKCODE_AGENT_PANEL_PUBLIC_BASE_URL=

# Enterprise WeChat / WeCom intelligent bot remote control.
# Start with: deepseekcode --wecom --project D:\code\DeepSeekTest
# DEEPSEEKCODE_WECOM_BOT_ID=your_wecom_bot_id
# DEEPSEEKCODE_WECOM_BOT_SECRET=your_wecom_bot_secret
# DEEPSEEKCODE_WECOM_WS_URL=wss://openws.work.weixin.qq.com
# DEEPSEEKCODE_WECOM_ALLOWED_USERS=userid1,userid2
# DEEPSEEKCODE_WECOM_ALLOWED_GROUPS=chatid1,chatid2
# DEEPSEEKCODE_WECOM_PROJECT_ROOTS=D:\code\DeepSeekTest;D:\work
# DEEPSEEKCODE_WECOM_MENTION_NAMES=DeepSeekCode,deepseekcode

# Personal WeChat OpenClaw remote control (experimental).
# First login: deepseekcode --wechat-login --project D:\code\DeepSeekTest
# Then start:  deepseekcode --wechat --project D:\code\DeepSeekTest
# DEEPSEEKCODE_WECHAT_OPENCLAW_ENABLED=true
# DEEPSEEKCODE_WECHAT_ACCOUNT_ID=
# DEEPSEEKCODE_WECHAT_API_BASE_URL=https://ilinkai.weixin.qq.com
# DEEPSEEKCODE_WECHAT_ALLOWED_USERS=
# DEEPSEEKCODE_WECHAT_ALLOWED_GROUPS=
# DEEPSEEKCODE_WECHAT_PROJECT_ROOTS=D:\code\DeepSeekTest;D:\work
# DEEPSEEKCODE_WECHAT_MENTION_NAMES=DeepSeekCode,deepseekcode
# DEEPSEEKCODE_WECHAT_QR_POLL_INTERVAL_MS=2000
# DEEPSEEKCODE_WECHAT_LONG_POLL_TIMEOUT_MS=35000
