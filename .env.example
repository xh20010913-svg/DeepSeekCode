# Copy this file to .env or set the variables in your local shell.

# deepseekCode v1 is DeepSeek-first. Use flash for live smoke tests.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEKCODE_LANGUAGE=zh-CN
DEEPSEEKCODE_MAX_OUTPUT_TOKENS=1200
DEEPSEEKCODE_REASONING_EFFORT=high

# Optional local cost-estimate overrides, in currency units per 1M tokens.
# DeepSeekCode includes DeepSeek defaults for deepseek-v4-flash/pro.
# DEEPSEEKCODE_PRICE_CURRENCY=USD
# DEEPSEEKCODE_PRICE_INPUT_PER_M=0.14
# DEEPSEEKCODE_PRICE_OUTPUT_PER_M=0.28
# DEEPSEEKCODE_PRICE_CACHE_HIT_PER_M=0.0028
# DEEPSEEKCODE_PRICE_CACHE_MISS_PER_M=0.14

# Optional provider profile JSON path. Prefer api_key_env entries in this file
# and keep real secrets in local environment variables.
# DEEPSEEKCODE_PROVIDER_CONFIG=D:\DeepSeekCodeData\providers.json

# Browser automation.
# DEEPSEEKCODE_BROWSER_CDP_URL=http://127.0.0.1:9222
# DEEPSEEKCODE_SEARCH_ENGINE=baidu
